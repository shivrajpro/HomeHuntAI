# Copy this file to .env and fill in the real values from your Supabase
# project dashboard (Settings -> API). Never commit the real .env file.

# Used by the frontend (src/lib/supabase.ts) — safe to expose in the browser.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Used ONLY by scripts/migrate-to-supabase.mjs, run from your machine.
# This key bypasses row-level security — never put it in VITE_-prefixed
# vars, never expose it to the frontend, never commit it.
SUPABASE_SERVICE_ROLE_KEY=
